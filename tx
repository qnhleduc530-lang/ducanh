        <ImageView android:id="@+id/dice1" android:layout_width="80dp" android:layout_height="80dp" android:src="@drawable/dice_1"/>
        <ImageView android:id="@+id/dice2" android:layout_width="80dp" android:layout_height="80dp" android:src="@drawable/dice_2"/>
        <ImageView android:id="@+id/dice3" android:layout_width="80dp" android:layout_height="80dp" android:src="@drawable/dice_3"/>
    </LinearLayout>

    <TextView android:id="@+id/resultText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tổng: 0" android:textSize="24sp" android:layout_marginTop="16dp"/>
    <TextView android:id="@+id/winLossText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textSize="28sp" android:layout_marginTop="8dp"/>

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="24dp">
        <Button android:id="@+id/taiButton" android:layout_width="100dp" android:layout_height="60dp" android:text="TÀI" android:textSize="20sp" android:background="@android:color/darker_gray"/>
        <Button android:id="@+id/xiuButton" android:layout_width="100dp" android:layout_height="60dp" android:text="XỈU" android:textSize="20sp" android:background="@android:color/darker_gray" android:layout_marginStart="16dp"/>
