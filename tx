package com.example.tailoc;

import android.os.Bundle;
import android.view.View;
import android.widget.Button;
import android.widget.ImageView;
import android.widget.TextView;
import android.widget.Toast;
import androidx.appcompat.app.AppCompatActivity;
import java.util.Random;

public class MainActivity extends AppCompatActivity {
    private ImageView dice1, dice2, dice3;
    private TextView resultText, winLossText;
    private Button taiButton, xiuButton, rollButton;
    private int selectedBet = 0; // 1=Tài, 2=Xỉu
    private Random rand = new Random();

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        dice1 = findViewById(R.id.dice1);
        dice2 = findViewById(R.id.dice2);
        dice3 = findViewById(R.id.dice3);
        resultText = findViewById(R.id.resultText);
        winLossText = findViewById(R.id.winLossText);
        taiButton = findViewById(R.id.taiButton);
        xiuButton = findViewById(R.id.xiuButton);
        rollButton = findViewById(R.id.rollButton);

        taiButton.setOnClickListener(v -> {
            selectedBet = 1;
            taiButton.setBackgroundColor(getResources().getColor(android.R.color.holo_blue_light));
            xiuButton.setBackgroundColor(getResources().getColor(android.R.color.darker_gray));
        });
        xiuButton.setOnClickListener(v -> {
            selectedBet = 2;
            xiuButton.setBackgroundColor(getResources().getColor(android.R.color.holo_blue_light));
            taiButton.setBackgroundColor(getResources().getColor(android.R.color.darker_gray));
        });
        rollButton.setOnClickListener(v -> rollDice());
    }

    private void rollDice() {
        if (selectedBet == 0) {
            Toast.makeText(this, "Vui lòng chọn Tài hoặc Xỉu", Toast.LENGTH_SHORT).show();
            return;
        }
        int d1 = rand.nextInt(6) + 1;
        int d2 = rand.nextInt(6) + 1;
        int d3 = rand.nextInt(6) + 1;
        setDiceImage(dice1, d1);
        setDiceImage(dice2, d2);
        setDiceImage(dice3, d3);
        int sum = d1 + d2 + d3;
        resultText.setText("Tổng: " + sum);
        boolean isTai = (sum >= 11 && sum <= 18);
        boolean win = (isTai && selectedBet == 1) || (!isTai && selectedBet == 2);
        winLossText.setText(win ? "Bạn thắng!" : "Bạn thua!");
        winLossText.setTextColor(getResources().getColor(win ? android.R.color.holo_green_dark : android.R.color.holo_red_dark));
    }

    private void setDiceImage(ImageView iv, int value) {
        int resId;
        switch (value) {
            case 1: resId = R.drawable.dice_1; break;
            case 2: resId = R.drawable.dice_2; break;
            case 3: resId = R.drawable.dice_3; break;
            case 4: resId = R.drawable.dice_4; break;
            case 5: resId = R.drawable.dice_5; break;
            default: resId = R.drawable.dice_6; break;
        }
        iv.setImageResource(resId);
    }
}

