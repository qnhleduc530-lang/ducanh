local FIXED_BOSS_POS = Vector3.new(-2790, 239, -1762)

-- ========== HÀM KIỂM TRA VỊ TRÍ ==========
local function isAreaOccupied(targetPos)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if (p.Character.HumanoidRootPart.Position - targetPos).Magnitude <= 7 then
                return true
            end
        end
    end
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Seat") or v:IsA("VehicleSeat") then
            if (v.Position - targetPos).Magnitude <= 7 and v.Occupant and v.Occupant.Parent ~= player.Character then
                return true
            end
        end
    end
    return false
end

local function interactWithSeatPrompt(targetPos)
    for _, prompt in ipairs(workspace:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") and (prompt.Parent:IsA("BasePart") or prompt.Parent:IsA("Model")) then
            if (prompt.Parent.Position - targetPos).Magnitude <= 6 then
                fireproximityprompt(prompt)
                break
            end
        end
    end
end

-- ========== ANTI AFK ==========
local function isAnyFarmActive()
    return _G.AntiAFKEnabled or _G.AutoFarmChua or _G.AutoFarmBanhMi or _G.AutoFarmBenhVien or _G.AutoFarmCaoSu or _G.AutoFarmChotCongAn or _G.AutoFarmSuKien or _G.AutoFarmMatOng or _G.TeleportToBoss or _G.AutoFarmBossCircle
end

LP.Idled:Connect(function()
    if isAnyFarmActive() then
        VirtualUser:Button2Down(Vector2.new(), camera.CFrame)
        task.wait(0.5)
        VirtualUser:Button2Up(Vector2.new(), camera.CFrame)
    end
end)

task.spawn(function()
    while true do
        task.wait(250)
        if isAnyFarmActive() then
            pcall(function()
                if not _G.FreecamEnabled and not _G.LockCameraEnabled and not _G.AutoAimBossNoCam then
                    camera.CFrame *= CFrame.Angles(0, math.rad(5), 0)
                end
                VirtualUser:Button2Down(Vector2.new(), camera.CFrame)
                task.wait(0.5)
                VirtualUser:Button2Up(Vector2.new(), camera.CFrame)
            end)
        end
    end
end)

-- ========== FARM CHÙA ==========
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.AutoFarmChua then
            pcall(function()
                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local humanoid = char and char:FindFirstChildOfClass("Humanoid")
                if hrp and humanoid and not humanoid.SeatPart then
                    local finalTarget = ToaDoChua1
                    if isAreaOccupied(ToaDoChua1) then
                        finalTarget = ToaDoChua2
                    end
                    hrp.CFrame = CFrame.new(finalTarget + Vector3.new(0, 2, 0))
                    task.wait(0.1)
                    interactWithSeatPrompt(finalTarget)
                end
            end)
        end
    end
end)

-- ========== FARM BÁNH MÌ ==========
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.AutoFarmBanhMi then
            pcall(function()
                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local humanoid = char and char:FindFirstChildOfClass("Humanoid")
                if hrp and humanoid and not humanoid.SeatPart then
                    local finalTarget = nil
                    for i = 1, #TDBanhMi do
                        if not isAreaOccupied(TDBanhMi[i]) then
                            finalTarget = TDBanhMi[i]
                            break
                        end
                    end
                    if not finalTarget then
                        finalTarget = TDBanhMi[1]
                    end
                    hrp.CFrame = CFrame.new(finalTarget + Vector3.new(0, 2, 0))
                    task.wait(0.1)
                    interactWithSeatPrompt(finalTarget)
                end
            end)
        end
    end
end)

