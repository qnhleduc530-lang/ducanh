-- ========== FARM BOSS CIRCLE ==========
_G.BossSettings = {
    TargetName = "NPC2",
    DashDist = 18.2,
    Speed = 0.05
}
local lastDashBoss = 0

task.spawn(function()
    while true do
        task.wait()
        if _G.AutoFarmBossCircle and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                local hrp = player.Character.HumanoidRootPart
            
