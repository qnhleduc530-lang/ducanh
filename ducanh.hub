-- ========== HÀM THÔNG BÁO ==========
local function notify(title, text, duration)
    duration = duration or 3
    Fluent:Notify({
        Title = title,
        Content = text,
        Duration = duration
    })
end

-- ========== HÀM TƯƠNG TÁC ==========
local function isAliveModel(model)
    if model and model:FindFirstChild("Humanoid") and model.Humanoid.Health > 0 then
        return true
    end
    return false
end

local function getNearestMonster()
    local char = LP.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local hrpPos = char.HumanoidRootPart.Position
    local closestMonster = nil
    local maxDistance = math.huge
    local targetFolder = workspace:FindFirstChild("Bosses") or workspace:FindFirstChild("Monsters") or workspace
    for _, obj in ipairs(targetFolder:GetChildren()) do
        if obj:IsA("Model") and isAliveModel(obj) and obj ~= char then
            if not Players:GetPlayerFromCharacter(obj) then
                local mHrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso")
                if mHrp then
                    local distance = (hrpPos - mHrp.Position).Magnitude
                    if distance < maxDistance then
                        maxDistance = distance
                        closestMonster = obj
                    end
                end
            end
        end
    end
    return closestMonster
end

-- ========== LOGIC FARM LEVEL ==========
local lockedTarget = nil
local lockedPosition = nil
local lastDash = 0
_G.Settings = {
    TargetName = "CityNPC",
    DashDist = 18.2,
    Speed = 0.05
}

task.spawn(function()
    while task.wait() do
        if _G.AutoFarmLevel then
            pcall(function()
                local character = LP.Character
                if not character then return end
                local hrp = character:FindFirstChild("HumanoidRootPart")
                local humanoid = character:FindFirstChild("Humanoid")
                if not hrp or not humanoid then return end

                if not lockedTarget or not lockedTarget.Parent or not lockedTarget:FindFirstChild("Humanoid") or lockedTarget.Humanoid.Health <= 0 then
                    lockedTarget = nil
                    lockedPosition = nil
                    for _, obj in pairs(Workspace:GetDescendants()) do
                        if obj.Name == _G.Settings.TargetName and obj:FindFirstChild("HumanoidRootPart") and obj:FindFirstChild("Humanoid") and obj.Humanoid.Health > 0 then
                            lockedTarget = obj
                            lockedPosition = obj.HumanoidRootPart.Position
                            break
                        end
                    end
                end

                if not lockedTarget then return end

                local targetHrp = lockedTarget:FindFirstChild("HumanoidRootPart")
                local targetHum = lockedTarget:FindFirstChild("Humanoid")
                if not targetHrp or not targetHum then
                    lockedTarget = nil
                    lockedPosition = nil
                    return
                end

                targetHrp.CFrame = CFrame.new(lockedPosition)
                targetHum.WalkSpeed = 0
                targetHum.JumpPower = 0
                targetHum.PlatformStand = true

                if tick() - lastDash >= _G.Settings.Speed then
                    lastDash = tick()
                    local offsets = {
                        Vector3.new(_G.Settings.DashDist, 0, 0),
                        Vector3.new(-_G.Settings.DashDist, 0, 0),
                        Vector3.new(0, 0, _G.Settings.DashDist),
                        Vector3.new(0, 0, -_G.Settings.DashDist)
                    }
                    local randomOffset = offsets[math.random(1, #offsets)]
                    hrp.CFrame = CFrame.lookAt(lockedPosition + randomOffset, lockedPosition)
                    hrp.AssemblyLinearVelocity = Vector3.zero

                    local tool = character:FindFirstChildOfClass("Tool")
                    if tool then
                        tool:Activate()
                        pcall(function() tool:Activate() end)
                    else
                        VirtualUser:CaptureController()
                        VirtualUser:Button1Down(Vector2.new(500, 500))
                        task.wait(0.03)
                        VirtualUser:Button1Up(Vector2.new(500, 500))
                    end
                end
            end)
        else
            lockedTarget = nil
            lockedPosition = nil
        end
    end
end)

-- ========== AUTO LOOT ==========
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.AutoLootEnabled or _G.AutoLootBossEnabled then
            pcall(function()
                local char = LP.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    for _, v in ipairs(workspace:GetDescendants()) do
                        if v:IsA("ProximityPrompt") then
                            local pos = v.Parent:IsA("BasePart") and v.Parent.Position or (v.Parent:IsA("Model") and v.Parent:GetPivot().Position)
                            if pos and (hrp.Position - pos).Magnitude <= 20 then
                                fireproximityprompt(v)
                            end
                        end
                        if v:IsA("TouchInterest") and v.Parent:IsA("BasePart") then
                            if (hrp.Position - v.Parent.Position).Magnitude <= 20 then
                                firetouchinterest(hrp, v.Parent, 0)
                                firetouchinterest(hrp, v.Parent, 1)
                            end
                        end
                    end
                end
            end)
        end
    end
end)

-- ========== TỌA ĐỘ FARM ==========
local ToaDoChua1 = Vector3.new(1561, 133, -244)
local ToaDoChua2 = Vector3.new(1547, 133, -245)
local TDBanhMi = {
    Vector3.new(573, 21, -357),
    Vector3.new(563, 20, -386),
    Vector3.new(553, 20, -413),
    Vector3.new(531, 21, -449)
}
local TDBenhVien = {
    Vector3.new(790, 22, -403),
    Vector3.new(790, 22, -413)
}
local TDCaoSu = {
    Vector3.new(1681, 19, -456),
    Vector3.new(1723, 19, -388)
}
local TDChotCongAn = Vector3.new(734, 20, -812)
local TDSuKien = Vector3.new(0, 0, 0)
local TDMatOng = {
    Vector3.new(567, 19, -533),
    Vector3.new(626, 19, -511),
    Vector3.new(629, 19, -419)
}
