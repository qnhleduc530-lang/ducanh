package com.example.fakelag;

import android.content.BroadcastReceiver;
import android.content.Context;
import android.content.Intent;
import android.os.Handler;
import android.os.Looper;
import android.util.Log;

import java.util.Random;
import java.util.concurrent.Executors;
import java.util.concurrent.ScheduledExecutorService;
import java.util.concurrent.TimeUnit;

/**
 * Lớp chính: LagSimulator – điều khiển độ trễ giả (fake lag)
 * Sử dụng singleton: LagSimulator.getInstance()
 */
public class LagSimulator {
    private static final String TAG = "LagSimulator";
    private static volatile LagSimulator instance;

    private final Random random = new Random();
    private final ScheduledExecutorService scheduler = Executors.newSingleThreadScheduledExecutor();
    private final Handler mainHandler = new Handler(Looper.getMainLooper());

    private volatile boolean enabled = false;
    private volatile int fixedDelayMs = 0;
    private volatile int minDelayMs = 0;
    private volatile int maxDelayMs = 0;
    private volatile double dropRate = 0.0;          // 0.0 – 1.0
    private volatile Mode mode = Mode.OFF;

    public enum Mode {
        OFF,          // Tắt trễ
        FIXED,        // Trễ cố định (fixedDelayMs)
        RANDOM,       // Trễ ngẫu nhiên trong [minDelayMs, maxDelayMs]
        NORMAL,       // Trễ theo phân phối chuẩn (trung bình = fixedDelayMs, độ lệch = 10% trung bình)
        BURST         // Trễ đột biến: mỗi lần trễ ngẫu nhiên từ 0 đến 2*fixedDelayMs, tần suất 1/10
    }

    private LagSimulator() {}

    public static LagSimulator getInstance() {
        if (instance == null) {
            synchronized (LagSimulator.class) {
                if (instance == null) {
                    instance = new LagSimulator();
                }
            }
        }
        return instance;
    }

    // -------------------- Cấu hình --------------------
    public synchronized void setMode(Mode mode) {
        this.mode = mode;
        this.enabled = (mode != Mode.OFF);
        Log.i(TAG, "Chế độ: " + mode.name());
    }

    public synchronized void setFixedDelay(int ms) {
        this.fixedDelayMs = Math.max(0, ms);
    }

    public synchronized void setRandomDelayRange(int minMs, int maxMs) {
        this.minDelayMs = Math.max(0, minMs);
        this.maxDelayMs = Math.max(minMs, maxMs);
    }

    public synchronized void setDropRate(double rate) {
        this.dropRate = Math.max(0.0, Math.min(1.0, rate));
    }

    // -------------------- Tính toán --------------------
    private int computeDelay() {
        if (!enabled) return 0;
        switch (mode) {
            case FIXED:
                return fixedDelayMs;
            case RANDOM:
                if (maxDelayMs <= minDelayMs) return minDelayMs;
                return minDelayMs + random.nextInt(maxDelayMs - minDelayMs + 1);
            case NORMAL:
                double sum = 0;
                for (int i = 0; i < 12; i++) sum += random.nextDouble();
                double z = sum - 6.0; // ~ N(0,1)
                int mean = fixedDelayMs;
                int std = Math.max(1, (int)(mean * 0.1)); // 10% độ lệch
                int delay = (int)(mean + z * std);
                return Math.max(0, delay);
            case BURST:
                if (random.nextInt(10) == 0) {
                    return random.nextInt(2 * fixedDelayMs + 1);
                } else {
                    return 0;
                }
            default:
                return 0;
        }
    }

    private boolean shouldDrop() {
        return enabled && dropRate > 0 && random.nextDouble() < dropRate;
    }

    // -------------------- API chính --------------------
    public boolean applyLag(Runnable task) {
        if (shouldDrop()) {
            Log.w(TAG, "Gói tin bị rơi (drop)");
            return false;
        }
        int delay = computeDelay();
        if (delay > 0) {
            scheduler.schedule(task, delay, TimeUnit.MILLISECONDS);
            Log.d(TAG, "Trì hoãn " + delay + "ms");
        } else {
            task.run();
        }
        return true;
    }

    public void applyLagOnUi(Runnable task) {
        if (shouldDrop()) {
            Log.w(TAG, "Gói tin UI bị rơi");
            return;
        }
        int delay = computeDelay();
        if (delay > 0) {
            mainHandler.postDelayed(task, delay);
        } else {
            mainHandler.post(task);
        }
    }

    public void shutdown() {
        scheduler.shutdownNow();
    }

    public String getStatus() {
        return String.format("enabled=%b, mode=%s, fixed=%d, min=%d, max=%d, drop=%.2f",
                enabled, mode.name(), fixedDelayMs, minDelayMs, maxDelayMs, dropRate);
    }

    // =============================================================
    // Lớp BroadcastReceiver nhúng bên trong để điều khiển từ xa
    // =============================================================
    public static class LagControlReceiver extends BroadcastReceiver {
        private static final String ACTION_SET_LAG = "com.example.fakelag.SET_LAG";
        private static final String EXTRA_MODE = "mode";
        private static final String EXTRA_FIXED = "fixedDelay";
        private static final String EXTRA_MIN = "minDelay";
        private static final String EXTRA_MAX = "maxDelay";
        private static final String EXTRA_DROP = "dropRate";

        @Override
        public void onReceive(Context context, Intent intent) {
            if (intent == null || !ACTION_SET_LAG.equals(intent.getAction())) return;

            LagSimulator sim = LagSimulator.getInstance();
            int modeVal = intent.getIntExtra(EXTRA_MODE, 0);
            Mode mode;
            switch (modeVal) {
                case 1: mode = Mode.FIXED; break;
                case 2: mode = Mode.RANDOM; break;
                case 3: mode = Mode.NORMAL; break;
                case 4: mode = Mode.BURST; break;
                default: mode = Mode.OFF;
            }
            sim.setMode(mode);

            if (intent.hasExtra(EXTRA_FIXED)) {
                sim.setFixedDelay(intent.getIntExtra(EXTRA_FIXED, 0));
            }
            if (intent.hasExtra(EXTRA_MIN) && intent.hasExtra(EXTRA_MAX)) {
                sim.setRandomDelayRange(
                        intent.getIntExtra(EXTRA_MIN, 0),
                        intent.getIntExtra(EXTRA_MAX, 100)
                );
            }
            if (intent.hasExtra(EXTRA_DROP)) {
                sim.setDropRate(intent.getDoubleExtra(EXTRA_DROP, 0.0));
            }

            Log.i("LagControl", "Đã cập nhật: " + sim.getStatus());
        }
    }
}

